# AI GC START
# HTTP 服务监听配置
APP_HOST=0.0.0.0
APP_PORT=8000
UVICORN_WORKERS=1

# 数据目录与数据库
APP_DATA_DIR=/app/data
APP_DB_PATH=/app/data/app.db

# 调用后端大模型的超时时间（秒）
APP_LLM_TIMEOUT_SECONDS=60

# 反向代理域名示例，仅供文档和飞书回调配置参考
PUBLIC_BASE_URL=https://your-domain.example.com

# MCP Server 调用主服务时使用的地址
FEISHU_CHAT_SERVICE_BASE_URL=http://127.0.0.1:8000
FEISHU_CHAT_SERVICE_TIMEOUT_SECONDS=60

# MCP Server 运行方式：stdio / sse / streamable-http
FEISHU_CHAT_MCP_TRANSPORT=stdio
FEISHU_CHAT_MCP_HOST=127.0.0.1
FEISHU_CHAT_MCP_PORT=9000

# MCP 内部定时任务存储与轮询间隔
FEISHU_CHAT_MCP_TASK_DB_PATH=/app/data/mcp_tasks.db
FEISHU_CHAT_MCP_SCHEDULER_POLL_SECONDS=5
# AI GC END
